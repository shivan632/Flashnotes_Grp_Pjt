digraph Roadmap {
  rankdir=TB;
  node [shape=box, style="rounded,filled", fillcolor="#1F2937", fontcolor="white", fontname="Arial", fontsize=12];
  edge [color="#3B82F6", penwidth=2, arrowhead="normal"];

  // Title: Complete Python Learning Path

  "1" [shape=box, style="rounded,filled", fillcolor="#3B82F6", fontcolor="white", penwidth=2, label="Python Introduction", tooltip="Start your journey to learn Python"];
  "2" [shape=box, style="rounded,filled", fillcolor="#1F2937", fontcolor="white", penwidth=1, label="Python Basics", tooltip="Learn basics of Python"];
  "2_1" [shape=box, style="rounded,filled", fillcolor="#111827", fontcolor="#E5E7EB", penwidth=1, label="Basics  Part 1", tooltip="Deep dive into basics"];
  "2_2" [shape=box, style="rounded,filled", fillcolor="#111827", fontcolor="#E5E7EB", penwidth=1, label="Basics  Part 2", tooltip="Deep dive into basics"];
  "3" [shape=box, style="rounded,filled", fillcolor="#1F2937", fontcolor="white", penwidth=1, label="Python Core Concepts", tooltip="Learn core concepts of Python"];
  "3_1" [shape=box, style="rounded,filled", fillcolor="#111827", fontcolor="#E5E7EB", penwidth=1, label="Core Concepts  Part 1", tooltip="Deep dive into core concepts"];
  "3_2" [shape=box, style="rounded,filled", fillcolor="#111827", fontcolor="#E5E7EB", penwidth=1, label="Core Concepts  Part 2", tooltip="Deep dive into core concepts"];
  "4" [shape=box, style="rounded,filled", fillcolor="#1F2937", fontcolor="white", penwidth=1, label="Python Practice", tooltip="Learn practice of Python"];
  "4_1" [shape=box, style="rounded,filled", fillcolor="#111827", fontcolor="#E5E7EB", penwidth=1, label="Practice  Part 1", tooltip="Deep dive into practice"];
  "4_2" [shape=box, style="rounded,filled", fillcolor="#111827", fontcolor="#E5E7EB", penwidth=1, label="Practice  Part 2", tooltip="Deep dive into practice"];
  "5" [shape=box, style="rounded,filled", fillcolor="#1F2937", fontcolor="white", penwidth=1, label="Python Simple Projects", tooltip="Learn simple projects of Python"];
  "5_1" [shape=box, style="rounded,filled", fillcolor="#111827", fontcolor="#E5E7EB", penwidth=1, label="Simple Projects  Part 1", tooltip="Deep dive into simple projects"];
  "5_2" [shape=box, style="rounded,filled", fillcolor="#111827", fontcolor="#E5E7EB", penwidth=1, label="Simple Projects  Part 2", tooltip="Deep dive into simple projects"];

  "1" -> "2";
  "2" -> "2_1";
  "2" -> "2_2";
  "1" -> "3";
  "3" -> "3_1";
  "3" -> "3_2";
  "1" -> "4";
  "4" -> "4_1";
  "4" -> "4_2";
  "1" -> "5";
  "5" -> "5_1";
  "5" -> "5_2";
}
